{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hosted generic IMU/GNSS replay datasets",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "datasets"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version", "files"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "homepage": {
            "type": "string",
            "format": "uri"
          },
          "license": {
            "type": "string"
          },
          "replay_dir": {
            "type": "string",
            "default": "."
          },
          "files": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "url", "sha256"],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "url": {
                  "type": "string",
                  "minLength": 1,
                  "description": "HTTP(S) URL or safe path relative to this manifest."
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[a-fA-F0-9]{64}$"
                },
                "bytes": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          },
          "smoke": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "max_imu_rows": {
                "type": "integer",
                "minimum": 1,
                "default": 1000
              },
              "max_gnss_rows": {
                "type": "integer",
                "minimum": 1,
                "default": 200
              },
              "misalignment": {
                "type": "string",
                "enum": ["internal", "external", "ref"],
                "default": "internal"
              }
            }
          }
        }
      }
    }
  }
}
